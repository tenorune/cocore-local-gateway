# TCP port the gateway listens on. 1234 = OFF GRID auto-scan slot.
GATEWAY_PORT=1234

# Overlay interface(s) to bind, comma-separated. Their current IPv4 is
# resolved at runtime and re-bound if it changes. ZeroTier on macOS = feth*.
# Examples: ZeroTier "feth3363", Tailscale "utun3", LAN "en0".
BIND_INTERFACES=feth3363

# Alternative to BIND_INTERFACES: explicit addresses, comma-separated.
# If set, these are added verbatim. 127.0.0.1 is ALWAYS bound regardless.
# BIND_ADDRESSES=127.0.0.1,10.121.33.197

# Directory holding the cocore engine sockets.
COCORE_SOCKET_DIR=~/.cocore/sockets

# Proxy log file.
LOG_PATH=~/.cocore/logs/local-gateway.log
